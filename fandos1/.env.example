# fandos — пример переменных окружения.
# Скопируйте в .env (git его игнорирует) и заполните. .env читается launch.json в VS Code.

# ── База данных (обязательно) ─────────────────────────────────────────────
DATABASE_URL=postgres://fandos:ПАРОЛЬ@localhost:5432/fandos

# ── Режим ─────────────────────────────────────────────────────────────────
RUN_MODE=dry_run                 # dry_run | live

# ── Адреса ────────────────────────────────────────────────────────────────
HTTP_ADDR=:8080                  # server: API + Mini App
PROM_ADDR=:9090                  # worker: метрики/health

# ── Master-ключ (обязателен для ввода/чтения ключей бирж) ─────────────────
# 32 байта в base64. Сгенерировать: head -c 32 /dev/urandom | base64
MASTER_KEY=ЗАМЕНИТЕ_НА_base64_32_байта
MASTER_KEY_ENV=MASTER_KEY

# ── Telegram ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:AA_ТОКЕН_ОТ_BOTFATHER
TELEGRAM_ADMIN_IDS=ВАШ_TELEGRAM_ID     # через запятую для нескольких
WEBAPP_DIR=webapp

# ── 2FA (опционально) ──────────────────────────────────────────────────────
# FANDOS_2FA_SECRET=общий_секрет       # пусто = 2FA выключена (dev)

# ── Часы (для LIVE обязательно указать реальные NTP-серверы) ───────────────
NTP_SERVERS=pool.ntp.org
MAX_CLOCK_OFFSET_MS=500

# ── Логи ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info                   # debug | info | warn | error

# ── Демо (только dry_run): включить ордера на mock-биржах ──────────────────
# FANDOS_DEMO_ORDERS=1
