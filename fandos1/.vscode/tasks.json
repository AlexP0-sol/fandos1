{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 fandos: гид по настройке",
      "detail": "Проверит окружение, создаст .env, соберёт проект и покажет, что делать дальше.",
      "type": "shell",
      "command": "bash scripts/setup.sh",
      "windows": { "command": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1" },
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": [],
      "runOptions": { "runOn": "folderOpen" }
    },
    {
      "label": "go: build all",
      "type": "shell",
      "command": "go build ./...",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$go"]
    },
    {
      "label": "go: test all",
      "type": "shell",
      "command": "go test ./... -count=1",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": ["$go"]
    },
    {
      "label": "go: test -race",
      "type": "shell",
      "command": "CGO_ENABLED=1 go test -race ./... -count=1",
      "problemMatcher": ["$go"]
    },
    {
      "label": "go: vet",
      "type": "shell",
      "command": "go vet ./...",
      "problemMatcher": ["$go"]
    },
    {
      "label": "go: gofmt (write)",
      "type": "shell",
      "command": "gofmt -w ."
    },
    {
      "label": "db: применить миграции",
      "type": "shell",
      "command": "for f in migrations/000*_*.sql; do echo \"=> $f\"; psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f \"$f\" || exit 1; done",
      "windows": { "command": "Get-ChildItem migrations/000*_*.sql | Sort-Object Name | ForEach-Object { Write-Host \"=> $($_.Name)\"; psql $env:DATABASE_URL -v ON_ERROR_STOP=1 -f $_.FullName }" },
      "problemMatcher": []
    }
  ]
}
