{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "worker: DRY_RUN (mock, без ордеров)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/worker",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "RUN_MODE": "dry_run",
        "NTP_SERVERS": ""
      },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "worker: DRY_RUN + демо-ордера (полный цикл на mock)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/worker",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "RUN_MODE": "dry_run",
        "NTP_SERVERS": "",
        "FANDOS_DEMO_ORDERS": "1"
      },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "worker: LIVE (реальные ордера!)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/worker",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "RUN_MODE": "live"
      },
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "server: API + Telegram Mini App",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/server",
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "env": {
        "WEBAPP_DIR": "${workspaceFolder}/webapp"
      }
    },
    {
      "name": "Отладка текущего теста (файл в редакторе)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}"
    }
  ],
  "compounds": [
    {
      "name": "worker + server (DRY_RUN)",
      "configurations": [
        "worker: DRY_RUN + демо-ордера (полный цикл на mock)",
        "server: API + Telegram Mini App"
      ]
    }
  ]
}