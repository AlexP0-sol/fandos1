# .env.example — шаблон переменных окружения для fundarbitrage.
# Скопируйте этот файл в .env и заполните реальными значениями.
# НИКОГДА не коммитьте .env с реальными секретами в git!
#
# cp .env.example .env
# $EDITOR .env

# ============================================================
# База данных PostgreSQL
# ============================================================

# Полный DSN для подключения к PostgreSQL.
# Формат: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://appuser:CHANGE_ME_DB_PASSWORD@postgres:5432/fundarbitrage?sslmode=disable

# Имя базы данных и пользователя (для docker compose postgres service).
POSTGRES_DB=fundarbitrage
POSTGRES_USER=appuser
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ============================================================
# Режим работы
# ============================================================

# RUN_MODE: dry_run | paper | testnet | live
# dry_run — по умолчанию (безопасно: ордера не выставляются).
# live — только после полной проверки чек-листа (RUNBOOK.md).
RUN_MODE=dry_run

# ============================================================
# Криптографические ключи
# ============================================================

# Base64-encoded 32-байтовый мастер-ключ для шифрования credential'ов.
# Генерация: openssl rand -base64 32
# НИКОГДА не сохраняйте реальный ключ в репозитории.
MASTER_KEY_B64=CHANGE_ME_BASE64_ENCODED_32_BYTE_MASTER_KEY

# ============================================================
# Telegram
# ============================================================

# Токен бота, полученный от @BotFather.
TELEGRAM_BOT_TOKEN=CHANGE_ME_BOT_TOKEN

# ============================================================
# HTTP и observability
# ============================================================

# Адрес HTTP-сервера (API + Mini App).
HTTP_ADDR=:8080

# Публичный базовый URL для Telegram Mini App (с https://).
PUBLIC_BASE_URL=https://CHANGE_ME_YOUR_DOMAIN

# Адрес Prometheus /metrics endpoint (worker).
PROM_ADDR=:9090

# Порт, пробрасываемый на хост для server-сервиса.
SERVER_PORT=8080

# Уровень логирования: debug | info | warn | error | critical.
LOG_LEVEL=info

# ============================================================
# Пул соединений с БД
# ============================================================

DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5

# ============================================================
# Clock sync (NTP)
# ============================================================

# Максимальный допустимый offset часов в мс (alert и SAFE_HALT при превышении).
MAX_CLOCK_OFFSET_MS=500

# Интервал синхронизации с NTP.
CLOCK_SYNC_INTERVAL=30s

# Список NTP-серверов через запятую.
NTP_SERVERS=pool.ntp.org,time.cloudflare.com

# ============================================================
# Таймауты
# ============================================================

# Таймаут graceful shutdown при получении SIGTERM.
SHUTDOWN_TIMEOUT=30s
